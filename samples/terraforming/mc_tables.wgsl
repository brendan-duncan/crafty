fn interp(a: f32, b: f32, iso: f32) -> f32 {
  let eps = 0.0001;
  if (abs(iso - b) < eps) {
    return 0.5;
  }
  if (abs(iso - a) < eps) {
    return 0.0;
  }
  return (iso - a) / (b - a);
}
